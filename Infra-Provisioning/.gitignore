# Ignore Terraform variable files and sensitive data
*.tfvars
*.tfvars.json
# Ignore Terraform state files
*.tfstate
*.tfstate.backup
# Ignore Terraform plan files
*.tfplan
# Ignore provider override files
override.tf
override.tf.json
# Ignore crash logs
crash.log
# Ignore sensitive files
secret.tf
secrets.tf
# Ignore .terraform directory
.terraform/